# ClipScribe — optional configuration for the ✨ AI-title button.
#
# Copy to `.env` and add your key to enable the optional "✨ AI title" feature
# (it names a saved transcript in 3–6 words). Everything else — transcription,
# diagnostics, exports, the library — works WITHOUT any of this, on your machine.
#
# Your Anthropic API key. Get one at https://console.anthropic.com/
# Never commit your real key — `.env` is gitignored; this `.env.example` is not.
ANTHROPIC_API_KEY=

# Default model for the AI-title (optional). Haiku is the cheapest and is plenty
# for a short title; you can also switch models in the app sidebar.
ANTHROPIC_MODEL=claude-haiku-4-5
